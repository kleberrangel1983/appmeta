{
  "name": "appmeta",
  "version": "0.1.0",
  "description": "REST API for storing and serving app metadata (name, version, description, tags).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "smoke": "bash .claude/skills/run-appmeta/smoke.sh"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
